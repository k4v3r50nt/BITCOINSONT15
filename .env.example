# Telegram (optional — bot works without it)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Trading parameters
PAPER_MODE=true
INITIAL_BANKROLL=100.0
MIN_CONFIDENCE=0.60
MAX_POSITION_PCT=0.05

# Web dashboard port (Railway overrides this with PORT automatically)
WEB_PORT=5000

# Bankroll persistence across Railway redeploys
# CURRENT_BANKROLL is updated automatically after every trade if the
# three Railway API vars below are configured.
# You can also set it manually in Railway → Variables after a session.
CURRENT_BANKROLL=

# Railway API — required for automatic CURRENT_BANKROLL updates
# RAILWAY_TOKEN:          railway.app → Account Settings → Tokens → New Token
# RAILWAY_SERVICE_ID:     Railway dashboard → your service → Settings → General
# RAILWAY_ENVIRONMENT_ID: Railway dashboard → environment URL (or service Settings)
RAILWAY_TOKEN=
RAILWAY_SERVICE_ID=
RAILWAY_ENVIRONMENT_ID=
